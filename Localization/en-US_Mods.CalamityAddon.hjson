# This file will automatically update with entries for new content after a build and reload.

Items: {
	WulfrumSword: {
		DisplayName: Wulfrum Sword
		Tooltip:
			'''
			Builds up charge upon enemy hits
			Building up enough charge allows you to press <right> to perform a dash
			[c/83B87E:'A giant wulfrum sword?! And it's a chargeable one!?']
			[c/83B87E:'Give me two!']
			'''
	}

	WulfrumPipe: {
		DisplayName: Wulfrum Pipe
		Tooltip: It was a tank gun
	}

	WulfrumLRocket: {
		DisplayName: Wulfrum Rocket
		Tooltip:
			'''
			Don't destroy blocks
			[c/83B87E:'With auto-aim']
			'''
	}

	WulfrumLuncher: {
		DisplayName: Wulfrum Launcher
		Tooltip: "[c/83B87E:'This is more powerful than you think.']"
	}

	WulfrumTankBanner: {
		DisplayName: Wulfrum Tank Banner
		Tooltip: ""
	}

	WulfrumWormBanner: {
		DisplayName: Wulfrum Digger Banner
		Tooltip: ""
	}

	WulfrumMothershipRelic: {
		DisplayName: Wulfrum Mothership Relic
		Tooltip: ""
	}

	WulfrumHeart: {
		Tooltip:
			'''
			Summons Wulfrum Mothership
			No consumable
			'''
		DisplayName: Wulfrum Heart
	}

	WulfrumMothershipBag: {
		Tooltip: "{$CommonItemTooltip.RightClickToOpen}"
		DisplayName: Wulfrum Sphere
	}

	Lore: {
		LoreWulfrumMothership: {
			DisplayName: Lore (Wulfrum Mothership)
			Tooltip:
				'''
				During the war, these majestic machines were in peak condition, 
				Boasting heavy armor and high maneuverability, but time spares no one... 
				Even though these Wulfrum Motherships have long since rusted over, 
				They remain a formidable foe to this day, still protected by lesser wulfrum creations.
				'''
		}
	}

	WulfrumBook: {
		DisplayName: Wulfrum Book
		Tooltip:
			'''
			Crafts wulfrum machines from mana
			[c/83B87E:'Engineering and commanding Wulfrum constructs.]
			[c/83B87E:Peak mechanical engineering!']
			'''
	}

	WulfrumStaff: {
		DisplayName: Wulfrum Staff
		Tooltip:
			'''
			Summons a protective turret
			[c/83B87E:'So powerful and cute!']
			'''
	}

	UnstableCore: {
		DisplayName: Unstable Core
		Tooltip: ""
	}
}

NPCs: {
	WulfrumTank: {
		DisplayName: Wulfrum Tank
		Bestiary: An armored patrol tank made of Wulfrum alloy. While these machines were relatively simple, they were very effective on the battlefield.
	}

	WulfrumWormBody.DisplayName: Wulfrum Digger

	WulfrumWormHead: {
		DisplayName: Wulfrum Digger
		Bestiary: These Wulfrum diggers were used to quickly tunnel through rock, but when the war began, their high armor and speed made them formidable opponents.
	}

	WulfrumWormTail.DisplayName: Wulfrum Digger

	WulfrumMothership: {
		DisplayName: Wulfrum Mothership
		Bestiary: A massive mothership that coordinates the actions of Wulfrum machines. Armed with homing missiles and a mini-factory, it can also charge other Wulfrum machines.
		SpawnInfo: Use a [i:CalamityAddon/WulfrumHeart] during the day on the surface.
		DespawnMessage: The Wulfrum Mothership has retreated...
	}

	WulfrumShield.DisplayName: Wulfrum Mothership

	WulfrumBomber: {
		DisplayName: Wulfrum Bomber
		Bestiary: Initially, the Wulfrum bombers were designed to transport various heavy cargoes by air, but when the war began, they were easily converted to carry and drop small bombs. When these appeared, the enemy fled.
	}
}

